
import xarray as xr
import rioxarray
import geopandas as gpd
import pandas as pd
import numpy as np

# =============================================================================
# INPUTS
# =============================================================================

nc_file = r"/caldera/hovenweep/projects/usgs/ecosystems/fresc/jhada/fire_season/FWI_nc/FWI_nc/fire_season/FWI_daily_11km_AgERA5_1980_2023.nc"
shp_file = r"/caldera/hovenweep/projects/usgs/ecosystems/fresc/jhada/fire_season/FWI_nc/Ecoregions_CONUS/Ecoregions_CONUS/Fire_Season/us_eco_l4.shp"

output_csv = r"/home/jhada/fire_season/output_csv/FireSeason_by_Ecoregion.csv"

FWI_VARIABLE = "FWI"      # change if your variable name differs
ECO_FIELD = "NA_L3Name"

CONSECUTIVE_DAYS = 3
PERCENTILE = 75

# =============================================================================
# LOAD DATA
# =============================================================================

ds = xr.open_dataset(nc_file)

fwi = ds[FWI_VARIABLE]last_consecutive

# rename coordinates if necessary
coord_map = {}
if "longitude" in fwi.coords:
    coord_map["longitude"] = "x"
if "latitude" in fwi.coords:
    coord_map["latitude"] = "y"

if coord_map:
    fwi = fwi.rename(coord_map)

# assign CRS if missing
if fwi.rio.crs is None:
    fwi = fwi.rio.write_crs("EPSG:4326")

eco = gpd.read_file(shp_file)

if eco.crs != fwi.rio.crs:
    eco = eco.to_crs(fwi.rio.crs)

# =============================================================================
# HELPER FUNCTIONS
# =============================================================================

def first_consecutive(mask, n=3):
    """
    Returns first index where mask is True for n consecutive days.
    """
    count = 0
    for i, val in enumerate(mask):
        if val:
            count += 1
            if count >= n:
                return i - n + 1
        else:
            count = 0
    return None


def last_consecutive(mask, n=3):
    """
    Returns last index where mask is True for n consecutive days.
    """
    count = 0
    for i in range(len(mask)-1, -1, -1):
        if mask[i]:
            count += 1
            if count >= n:
                return i + n - 1
        else:
            count = 0
    return None

# =============================================================================
# PROCESS EACH ECOREGION
# =============================================================================

results = []

years = np.unique(fwi.time.dt.year.values)

for idx, row in eco.iterrows():

    name = row[ECO_FIELD]

    print(f"Processing {name}")

    geom = [row.geometry]

    try:
        clipped = fwi.rio.clip(geom, eco.crs, drop=True)
    except Exception:
        continue

    # Spatial average for each day
    ts = clipped.mean(dim=("y", "x"), skipna=True)

    series = ts.to_series()

    if series.isna().all():
        continue

    threshold = np.nanpercentile(series.values, PERCENTILE)

    for yr in years:

        annual = series[series.index.year == yr]

        if len(annual) == 0:
            continue

        mask = annual.values > threshold

        start_idx = first_consecutive(mask, CONSECUTIVE_DAYS)
        end_idx = last_consecutive(mask, CONSECUTIVE_DAYS)

        if start_idx is None or end_idx is None:

            results.append({
                "Year": yr,
                "NA_L3Name": name,
                "SeasonStart": np.nan,
                "SeasonEnd": np.nan,
                "LengthDays": 0,
                "Threshold": threshold
            })

            continue

        start_date = annual.index[start_idx]
        end_date = annual.index[end_idx]

        length = (end_date - start_date).days + 1

        results.append({
            "Year": yr,
            "NA_L3Name": name,
            "SeasonStart": start_date.strftime("%Y-%m-%d"),
            "SeasonEnd": end_date.strftime("%Y-%m-%d"),
            "LengthDays": length,
            "Threshold": threshold
        })

# =============================================================================
# SAVE
# =============================================================================

df = pd.DataFrame(results)

df.to_csv(output_csv, index=False)

print(df.head())

print("Finished.")